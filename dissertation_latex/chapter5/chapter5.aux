\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces System model overview. User submits intent $\zeta (t)$ to the Agentic Framework $\mathcal  {A}$, which exchanges prompts $\mathbf  {p}$ and validated outputs $\mathbf  {z}$ with \ac {LLM} validation. The Service Orchestrator $\mathcal  {O}$ mediates between framework and infrastructure, translating agentic commands to K8s \ac {API} calls and returning formatted state $\mathbf  {u}(t)$. Services $s_j$ are placed on nodes $n_i$, and the framework returns response $\rho (t)$ to the user.}}{110}{figure.caption.191}\protected@file@percent }
\acronymused{LLM}
\acronymused{API}
\newlabel{fig:ch5_system_model}{{5.1}{110}{System model overview. User submits intent $\zeta (t)$ to the Agentic Framework $\mathcal {A}$, which exchanges prompts $\mathbf {p}$ and validated outputs $\mathbf {z}$ with \ac {LLM} validation. The Service Orchestrator $\mathcal {O}$ mediates between framework and infrastructure, translating agentic commands to K8s \ac {API} calls and returning formatted state $\mathbf {u}(t)$. Services $s_j$ are placed on nodes $n_i$, and the framework returns response $\rho (t)$ to the user}{figure.caption.191}{}}
